{
  "name": "react-typescript",
  "version": "1.0.0",
  "description": "React and TypeScript example starter project",
  "keywords": [
    "typescript",
    "react",
    "starter"
  ],
  "main": "src/index.tsx",
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mdi/js": "7.4.47",
    "@mdi/react": "1.6.1",
    "@mui/material": "5.18.0",
    "@mui/styles": "5.18.0",
    "@types/lodash": "4.17.24",
    "i18next": "21.10.0",
    "lodash": "4.18.1",
    "mobx": "6.15.0",
    "mobx-react": "9.2.1",
    "notistack": "3.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "11.18.6",
    "react-router-dom": "5.3.4",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "eslint": "^8.57.1",
    "typescript": "4.9.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "react-scripts test --env=jsdom --watchAll=false --coverage",
    "eject": "react-scripts eject"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/components/AppHeader/index.tsx",
      "src/components/AvatarMenu/index.tsx",
      "src/pages/Home/index.tsx",
      "src/pages/AccessDenied/index.tsx",
      "src/api/services/User/store.ts",
      "src/utils/global.ts",
      "src/utils/router.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
